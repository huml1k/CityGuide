{
  "ConnectionStrings": {
    "DefaultConnection": "Host=notification-db;Port=5432;Database=notification_db;Username=cityguide;Password=cityguide"
  },
  "CityGuideAuth": {
    "JwtIssuer": "CityGuide.AuthService",
    "JwtAudience": "CityGuide.Services",
    "JwtSecret": "super-secret-key-change-in-production-cityguide-auth",
    "ValidateLifetime": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "SubscribedTopics": [ "user.favorites", "content.routes", "content.moderation" ],
    "Topics": {
      "DeadLetterQueue": "notification-service-dlq"
    }
  },
  "AllowedHosts": "*"
}
