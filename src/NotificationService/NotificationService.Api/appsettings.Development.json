{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=6003;Database=notification_db;Username=cityguide;Password=cityguide"
  },
  "CityGuideAuth": {
    "JwtIssuer": "CityGuide.AuthService",
    "JwtAudience": "CityGuide.Services",
    "JwtSecret": "super-secret-key-change-in-production-cityguide-auth",
    "ValidateLifetime": true,
    "EnableIntrospection": true,
    "IntrospectionBaseUrl": "http://localhost:8081",
    "IntrospectionPath": "/api/auth/introspect"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "SubscribedTopics": [ "user.events", "content.events" ],
    "Topics": {
      "DeadLetterQueue": "notification-service-dlq"
    }
  }
}
