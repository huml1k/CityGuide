{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information",
      "Yarp.ReverseProxy.Forwarder": "Debug",
      "CityGuide.ApiGateway": "Debug"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss.fff ",
        "IncludeScopes": true
      }
    }
  },

  "AllowedHosts": "*",

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:5500",
      "http://127.0.0.1:5500",
      "http://127.0.0.1:8080",
      "http://localhost:8080",
      "https://cityguide.ru"
    ]
  },

  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "AuthorizationPolicy": "Anonymous"
      },
      "user-profiles-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/UserProfiles/{**catch-all}"
        },
        "AuthorizationPolicy": "Anonymous"
      },
      "favorites-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/Favorites/{**catch-all}"
        },
        "AuthorizationPolicy": "Anonymous"
      },
      "content-routes-route": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/routes/{**catch-all}"
        },
        "AuthorizationPolicy": "Anonymous"
      },
      "content-routes-root": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/routes"
        },
        "AuthorizationPolicy": "Anonymous"
      },
      "content-files-route": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/files/{**catch-all}"
        },
        "AuthorizationPolicy": "Anonymous"
      },
      "content-tags-route": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/tags/{**catch-all}"
        },
        "AuthorizationPolicy": "Anonymous"
      },
      "content-tags-root": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/tags"
        },
        "AuthorizationPolicy": "Anonymous"
      },
      "content-route-stats-route": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/route-stats/{**catch-all}"
        },
        "AuthorizationPolicy": "Anonymous"
      },
      "content-internal-routes": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/internal/routes/{**catch-all}"
        },
        "AuthorizationPolicy": "Anonymous"
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        },
        "AuthorizationPolicy": "Anonymous"
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://authservice:8080"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user-destination": {
            "Address": "http://userservice:8080"
          }
        }
      },
      "content-cluster": {
        "Destinations": {
          "content-destination": {
            "Address": "http://contentservice:8080"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-destination": {
            "Address": "http://notificationservice:8080"
          }
        }
      }
    }
  }
}
