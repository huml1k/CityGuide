{
  "ConnectionStrings": {
    "DefaultConnection": "Host=user-db;Port=5432;Database=user_db;Username=cityguide;Password=cityguide"
  },
  "CityGuideAuth": {
    "JwtIssuer": "CityGuide.AuthService",
    "JwtAudience": "CityGuide.Services",
    "JwtSecret": "super-secret-key-change-in-production-cityguide-auth",
    "ValidateLifetime": true,
    "EnableIntrospection": true,
    "IntrospectionBaseUrl": "http://authservice:8080",
    "IntrospectionPath": "/api/auth/introspect"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kafka": {
    "BootstrapServers": "kafka:9092"
  },
  "AllowedHosts": "*"
}
