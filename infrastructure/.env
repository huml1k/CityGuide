TAG=dev
REGISTRY=local

# ASP.NET для контейнеров API (профиль apps). Локальный dotnet run всегда Development из launchSettings.
# Development = Swagger; Production = без Swagger.
# Локальная разработка: .\infrastructure\start-infra.ps1 + dotnet run (appsettings.Development → localhost:6000…)
# Всё в Docker: .\infrastructure\deploy.ps1
ASPNETCORE_ENVIRONMENT=Development

# API (localhost)
GATEWAY_PORT=8080
AUTH_PORT=8081
USER_PORT=8082
CONTENT_PORT=8083
NOTIFICATION_PORT=8084
ADMIN_PORT=8085

# PostgreSQL (localhost → mapped from container 5432)
ADMIN_DB_PORT=6000
USER_DB_PORT=6001
CONTENT_DB_PORT=6002
NOTIFICATION_DB_PORT=6003
ADMIN_DB_NAME=admin_db
ADMIN_DB_USER=cityguide
ADMIN_DB_PASSWORD=cityguide
USER_DB_NAME=user_db
USER_DB_USER=cityguide
USER_DB_PASSWORD=cityguide
CONTENT_DB_NAME=content_db
CONTENT_DB_USER=cityguide
CONTENT_DB_PASSWORD=cityguide
NOTIFICATION_DB_NAME=notification_db
NOTIFICATION_DB_USER=cityguide
NOTIFICATION_DB_PASSWORD=cityguide

# Redis / Kafka / MinIO / pgAdmin (localhost)
REDIS_PORT=6379
REDIS_COMMANDER_PORT=8086
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
PGADMIN_PORT=5050
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
